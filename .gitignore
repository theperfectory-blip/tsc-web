# ─── Dependencias ───
node_modules/
yarn.lock
pnpm-lock.yaml

# ─── Claude Code (local) ───
.claude/settings.local.json

# ─── Graphify (artefactos regenerables) ───
# Conservamos GRAPH_REPORT.md (documentación), ignoramos lo pesado/cacheado
# Patrón global: atrapa graphify-out en cualquier subcarpeta
**/graphify-out/cache/
**/graphify-out/graph.html
**/graphify-out/graph.json
**/graphify-out/.graphify_chunk_*.json

# ─── Firebase (futuro backend) ───
.firebase/
firebase-debug.log*
firestore-debug.log*
ui-debug.log*
# NUNCA subir credenciales de servicio
*serviceAccount*.json
*-firebase-adminsdk-*.json
.runtimeconfig.json

# ─── Variables de entorno / secretos ───
.env
.env.*
!.env.example

# ─── Configuración local (cada desarrollador usa su Firebase proyecto) ───
tsc-src/js/firebase-config.js
tsc-src/js/cloudinary.js
# Ver DEPLOY.md para instrucciones de configuración

# ─── App nativa Android (Capacitor) — el proyecto SÍ se versiona, solo
#     sus artefactos de build quedan afuera (ver android/.gitignore) ───
*.apk
*.aab
/dist/
/www/

# ─── Logs locales de servidores de desarrollo (npx serve, etc.) ───
tsc-src/.serve-*.log

# ─── Sistema operativo ───
Thumbs.db
desktop.ini
.DS_Store

# ─── Editores ───
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*~

# ─── Locales / no van a main (sacados del control de versión, se conservan en disco) ───
tsc-src/prototype.html
tsc-src/palmares 3d/
HISTORIAL ENCUENTROS TSC FINAL.ods
