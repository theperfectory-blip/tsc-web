{
  "firestore": {
    "rules": "firebase/firestore.rules",
    "indexes": "firebase/firestore.indexes.json"
  },
  "hosting": {
    "site": "teamsubscup",
    "public": "tsc-src",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/graphify-out/**"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|html)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ]
  }
}
