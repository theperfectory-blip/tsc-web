rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Trofeos: lectura pública, escritura prohibida
    match /trophies/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Logos de equipos: lectura pública, escritura solo autenticados
    match /logos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Todo lo demás: denegado
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
