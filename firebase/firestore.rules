rules_version = '2';

// ============================================================
//  Reglas de seguridad Firestore — TSC Web
//  Modelo de roles: public (anónimo) · president · admin
//  El rol y el teamId viven en users/{uid} y los asigna el admin.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn()    { return request.auth != null; }
    function meExists()    { return exists(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function me()          { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isAdmin()     { return signedIn() && meExists() && me().role == 'admin'; }
    function isPresident() { return signedIn() && meExists() && me().role == 'president'; }

    // --- Colecciones del torneo: lectura PÚBLICA, escritura solo admin ---
    match /seasons/{id}        { allow read: if true; allow write: if isAdmin(); }
    match /competitions/{id}   { allow read: if true; allow write: if isAdmin(); }
    match /phases/{id}         { allow read: if true; allow write: if isAdmin(); }
    match /matches/{id}        { allow read: if true; allow write: if isAdmin(); }
    match /coins/{id}          { allow read: if true; allow write: if isAdmin(); }
    match /history/{id}        { allow read: if true; allow write: if isAdmin(); }
    match /settings/{id}       { allow read: if true; allow write: if isAdmin(); }
    match /matchHistory/{id}   { allow read: if true; allow write: if isAdmin(); }
    match /sorteo/{id}         { allow read: if true; allow write: if isAdmin(); }
    match /palmares/{id}       { allow read: if true; allow write: if isAdmin(); }
    match /palmares-comps/{id} { allow read: if true; allow write: if isAdmin(); }
    match /calDayLabels/{id}   { allow read: if true; allow write: if isAdmin(); }

    // --- Equipos: el presidente edita SU equipo ---
    match /teams/{teamId} {
      allow read: if true;
      allow update: if isAdmin()
                    || (isPresident() && me().teamId != null && string(me().teamId) == teamId && me().lockEdits != true);
      allow create, delete: if isAdmin();
    }

    // --- Perfiles de usuario ---
    match /users/{uid} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid);

      // Auto-registro: el usuario crea SU propio perfil, forzado a
      // presidente sin equipo (no puede auto-ascenderse a admin).
      allow create: if signedIn()
                    && request.auth.uid == uid
                    && request.resource.data.role == 'president'
                    && request.resource.data.teamId == null;

      // Edita su propio perfil SIN tocar rol ni equipo; el admin puede todo.
      allow update: if isAdmin()
                    || (request.auth.uid == uid
                        && !request.resource.data.diff(resource.data)
                              .affectedKeys().hasAny(['role','teamId','lockEdits']));

      // Cada quien puede borrar su propia cuenta; el admin, cualquiera.
      allow delete: if isAdmin() || request.auth.uid == uid;
    }

    // --- Contadores de IDs enteros (emulan autoIncrement) ---
    // Solo admin: un presidente no debe poder manipular IDs
    match /_counters/{c} {
      allow read:  if true;
      allow write: if isAdmin();
    }
  }
}
